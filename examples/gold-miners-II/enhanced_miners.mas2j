/*
 * Enhanced Gold Miners II
 * uses enhanced_miner.asl with fatigue handling,
 * better goal decisions, and A* pathfinding
 */

MAS enhanced_miners {
    environment: env.MiningEnvironment(11, 100, yes, "dummy", "miner", 1000)
        // parameters: 1. environment configuration id (from 1 to 13)
        //             2. sleep time (in ms) after each action
        //             3. whether display the gui
        //             4. name of the agents of red team (opponents)
        //             5. name of the agents of blue team (our team)
        //             6. window size

    agents:
        // red team (opponents — dummy agents)
        dummy agentArchClass arch.LocalMinerArch #6;

        // blue team (our enhanced agents)
        leader
               beliefBaseClass agent.DiscardBelsBB("my_status","picked","committed_to","cell");

        miner  enhanced_miner.asl
               agentClass agent.SelectEvent
               beliefBaseClass agent.UniqueBelsBB("gsize(_,_,_)","depot(_,_,_)","steps(_,_)","committed_to(_,_,key)")
               agentArchClass arch.LocalMinerArch
               #6;

    aslSourcePath: "asl";
}
